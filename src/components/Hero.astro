---
const phrases = [
    "Copiando de StackOverflow desde 2010.",
    "Mi código no tiene bugs, tiene features inesperadas.",
    "Desarrollo impulsado por memes y cafeína.",
    "Funciona en mi local, y eso es lo que cuenta.",
    "Git commit -m 'no sé qué hice pero funciona'",
    "Junior en el código, Senior en los memes.",
    "¿Testing? Yo debugueo en producción.",
];

const randomPhrase = phrases[Math.floor(Math.random() * phrases.length)];
---

<section class="hero container">
    <div class="hero-content">
        <div class="logo-wrapper">
            <img
                src="/images/logo.png"
                alt="DesarrolloImpulsadaPorMemes Logo"
                class="main-logo"
            />
        </div>
        <div class="text-wrapper">
            <h1 class="hero-title">Programación Impulsada por Memes</h1>
            <p class="phrase">{randomPhrase}</p>
        </div>
    </div>
</section>

<style>
    .hero {
        padding: 6rem 0 3rem;
        text-align: center;
    }

    .hero-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .logo-wrapper {
        max-width: 240px;
    }

    .main-logo {
        width: 100%;
        height: auto;
        filter: drop-shadow(0 10px 40px rgba(0, 0, 0, 0.1));
        animation: float 6s ease-in-out infinite;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--fg);
        margin-bottom: 0.5rem;
        letter-spacing: -0.03em;
    }

    .phrase {
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--accent);
        opacity: 0.9;
    }

    @keyframes float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-15px);
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 4rem 1rem 2rem;
        }
        .logo-wrapper {
            max-width: 180px;
        }
        .hero-title {
            font-size: 1.8rem;
        }
        .phrase {
            font-size: 1.1rem;
        }
    }
</style>
