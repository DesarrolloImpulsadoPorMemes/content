---
import { SITE } from "../config";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: URL | string;
  type?: "website" | "article";
}

const {
  title = SITE.title,
  description = SITE.description,
  image = "/images/logo.png",
  canonicalURL = Astro.url,
  type = "website",
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta
  name="keywords"
  content="memes programación, humor dev, bugs, junior vs senior, código, memes it, programacion, programador, desarrollador, software, tecnologia, informatica, humor, risas, programacion impulsada por memes"
/>
<meta name="author" content="DesarrolloImpulsadaPorMemes" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Theme color selection -->
<meta name="theme-color" content="#1A2B34" />

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "DesarrolloImpulsadoPorMemes",
    "description": "Galería de memes dedicada al mundo del desarrollo de software y la programación.",
    "url": "https://desarrolloimpulsadopormemes.github.io",
    "about": {
      "@type": "Thing",
      "name": "Software Development Humor"
    },
    "creator": {
      "@type": "Person",
      "name": "DesarrolloImpulsadaPorMemes"
    }
  }
</script>
